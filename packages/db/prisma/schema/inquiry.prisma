model Inquiry {
  id                String        @id @default(cuid())
  fullName          String
  mobile            String
  preferredLocation String?
  message           String?       @db.Text
  status            InquiryStatus @default(NEW)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("inquiry")
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED
}
