{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@test_1/api": "workspace:*",
    "@test_1/auth": "workspace:*",
    "@test_1/db": "workspace:*",
    "@test_1/env": "workspace:*",
    "@ts-rest/core": "catalog:",
    "@ts-rest/serverless": "^3.52.1",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "express": "^5.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@test_1/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/express": "^5.0.6",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  }
}
